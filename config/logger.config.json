{
	"version": 1,
	"disable_existing_loggers": false,
	"formatters": {
		"standard": {
			"format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
		}
	},
	"handlers": {
		"file": {
			"class": "logging.handlers.RotatingFileHandler",
			"level": "DEBUG",
			"formatter": "standard",
			"filename": "logs/latest.log",
			"maxBytes": 1048576,
			"backupCount": 5,
			"encoding": "utf8"
		}
	},
	"loggers": {
		"": {
			"handlers": ["file"],
			"level": "DEBUG",
			"propagate": true
		}
	}
}
